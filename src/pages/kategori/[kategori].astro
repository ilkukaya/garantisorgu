---
import Layout from '../../components/Layout.astro';
import GarantiHesaplayici from '../../components/GarantiHesaplayici.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { loadKategoriBySlug, loadKategoriler, getKategoriMarkalar, loadMarkalar } from '../../lib/dataLoader';

export function getStaticPaths() {
  const kategoriler = loadKategoriler();
  return kategoriler.kategoriler.map((kategori: any) => ({
    params: { kategori: kategori.slug },
    props: { kategori }
  }));
}

const { kategori } = Astro.props;
const kategoriMarkalar = getKategoriMarkalar(kategori.id);
const markalarData = loadMarkalar();

const sssSorulari = [
  {
    baslik: `${kategori.ad} garanti süresi kaç yıl?`,
    icerik: `Türkiye'de 6502 sayılı Tüketici Koruma Kanunu'na göre ${kategori.ad.toLowerCase()} için zorunlu garanti süresi 2 yıldır. Bazı markalar ek garanti süreleri sunabilir.`
  },
  {
    baslik: `Hangi ${kategori.ad.toLowerCase()} markası en uzun garantiyi veriyor?`,
    icerik: `Yukarıdaki tabloda tüm markaların ${kategori.ad.toLowerCase()} garanti sürelerini karşılaştırabilirsiniz. Genellikle büyük markalar 2 yıl standart + ek bileşen garantisi sunmaktadır.`
  }
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sssSorulari.map(s => ({
    "@type": "Question",
    "name": s.baslik,
    "acceptedAnswer": { "@type": "Answer", "text": s.icerik }
  }))
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://garantisorgu.com" },
    { "@type": "ListItem", "position": 2, "name": "Kategoriler", "item": "https://garantisorgu.com/kategori/" },
    { "@type": "ListItem", "position": 3, "name": kategori.ad, "item": `https://garantisorgu.com/kategori/${kategori.slug}` }
  ]
});
---

<Layout
  title={`${kategori.ad} Garanti Süresi — Tüm Markalar Karşılaştırması | GarantiSorgu`}
  description={`${kategori.ad} için tüm markaların garanti sürelerini karşılaştırın. ${kategori.ad.toLowerCase()} alırken garanti nelere dikkat edilmeli?`}
  schemaMarkup={`${faqSchema}\n${breadcrumbSchema}`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-primary">Ana Sayfa</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li><a href="/kategori/" class="hover:text-primary">Kategoriler</a></li>
        <li><span class="text-gray-400">/</span></li>
        <li class="text-gray-900 font-medium">{kategori.ad}</li>
      </ol>
    </nav>

    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">{kategori.ad} Garanti Süreleri — Tüm Markalar</h1>
    {kategori.aciklama && <p class="text-gray-600 mb-8">{kategori.aciklama}</p>}

    <!-- Hızlı Hesaplayıcı -->
    <div class="mb-12">
      <GarantiHesaplayici />
    </div>

    <!-- Marka Karşılaştırma Tablosu -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Marka Karşılaştırma: {kategori.ad}</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Marka</th>
              <th class="text-center px-4 py-3 font-semibold text-gray-700">Standart Garanti</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Ek Garanti</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Notlar</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {kategoriMarkalar.map(m => {
              const ekGaranti = [];
              if (m.kompressor_garanti_yil) ekGaranti.push(`Kompresör: ${m.kompressor_garanti_yil} yıl`);
              if (m.motor_garanti_yil) ekGaranti.push(`Motor: ${m.motor_garanti_yil} yıl`);
              if (m.panel_garanti_yil) ekGaranti.push(`Panel: ${m.panel_garanti_yil} yıl`);
              return (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <a href={`/marka/${m.slug}`} class="font-semibold text-primary hover:underline">
                      {m.ad}
                    </a>
                  </td>
                  <td class="px-4 py-3 text-center font-semibold text-gray-900">
                    {m.garanti_yil} yıl
                  </td>
                  <td class="px-4 py-3 text-gray-600">
                    {ekGaranti.join(', ') || '—'}
                  </td>
                  <td class="px-4 py-3 text-gray-500 text-xs max-w-xs">
                    {m.notlar || '—'}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Bilgi İçeriği -->
    <div class="prose prose-sm max-w-none mb-12 bg-blue-50 rounded-xl p-6 sm:p-8 border border-blue-100">
      <h2 class="text-xl font-bold text-gray-900">{kategori.ad} Alırken Garanti Nelere Dikkat Edilmeli?</h2>
      <p class="text-gray-600">
        {kategori.ad.toLowerCase()} satın alırken garanti süresi kadar garanti kapsamı da önemlidir.
        Türkiye'de yasal garanti süresi 2 yıl olmakla birlikte, bazı markalar bileşen bazında
        daha uzun garanti süreleri sunabilmektedir.
      </p>
      <ul class="text-gray-600 list-disc pl-5 space-y-1">
        <li>Faturanızı mutlaka saklayın — garanti başlangıcı fatura tarihinden itibaren başlar</li>
        <li>Ek garanti bileşenlerini (motor, kompresör, panel) kontrol edin</li>
        <li>Yetkili servis ağı genişliğini araştırın</li>
        <li>Uzatılmış garanti seçeneklerini değerlendirin</li>
      </ul>
    </div>

    <!-- SSS -->
    <div class="max-w-3xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Sıkça Sorulan Sorular</h2>
      <div class="space-y-3">
        {sssSorulari.map(soru => (
          <FAQAccordion baslik={soru.baslik} icerik={soru.icerik} />
        ))}
      </div>
    </div>
  </div>
</Layout>
