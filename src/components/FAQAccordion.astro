---
interface Props {
  baslik: string;
  icerik: string;
  open?: boolean;
}

const { baslik, icerik, open = false } = Astro.props;
---

<details class="group border border-gray-200 rounded-lg" {open}>
  <summary class="flex items-center justify-between cursor-pointer p-4 text-left font-medium text-gray-900 hover:bg-gray-50 rounded-lg transition-colors list-none">
    <span>{baslik}</span>
    <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>
  <div class="px-4 pb-4 text-gray-600 leading-relaxed">
    {icerik}
  </div>
</details>
